generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPRESA
  TRANSPORTISTA
  AGENTE
  ADMIN
  SUPERADMIN
}

enum ShipmentType {
  IMPORT
  EXPORT
}

enum TransportMode {
  SEA
  AIR
  GROUND
}

enum ShipmentStatus {
  DRAFT
  CONFIRMED
  IN_TRANSIT
  AT_CUSTOMS
  DELIVERED
  CANCELLED
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CONVERTED
}

enum DocumentType {
  BILL_OF_LADING
  COMMERCIAL_INVOICE
  PACKING_LIST
  CUSTOMS_DECLARATION
  CERTIFICATE_OF_ORIGIN
  INSURANCE
  OTHER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum CustomsStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  RELEASED
}

enum FoodImportStatus {
  DRAFT
  DOCUMENTS_PENDING
  SIGIE_READY
  SIGIE_SUBMITTED
  MAGA_REVIEW
  LAB_PENDING
  LAB_APPROVED
  LAB_REJECTED
  QUARANTINE
  APPROVED
  RELEASED
  REJECTED
}

// Status del expediente de importación MX→GT
enum ExpedienteStatus {
  CFDI_PENDIENTE
  DOCS_GENERADOS
  SIGIE_SOLICITADO
  SIGIE_APROBADO
  DUCA_LISTA
  DUCA_TRANSMITIDA
  SEMAFORO_VERDE
  SEMAFORO_ROJO
  LIBERADA
  RECHAZADA
}

model Company {
  id        String   @id @default(cuid())
  name      String
  taxId     String?
  address   String?
  phone     String?
  country   String   @default("GT")
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  password        String
  firstName       String
  lastName        String
  role            Role              @default(EMPRESA)
  companyId       String?
  company         Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  refreshTokens   RefreshToken[]
  shipments       Shipment[]
  quotes          Quote[]
  documents       Document[]
  payments        Payment[]
  foodImports     FoodImport[]
  expedientes     ImportExpediente[]
  credentials     UserCredentials[]
  activityLogs    ActivityLog[]
  isActive        Boolean           @default(true)
  phone           String?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Quote {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        ShipmentType
  mode        TransportMode
  origin      String
  destination String
  weight      Float
  volume      Float?
  description String?
  carrier     String
  price       Float
  currency    String        @default("USD")
  transitDays Int
  validUntil  DateTime
  status      QuoteStatus   @default(PENDING)
  shipments   Shipment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

model Shipment {
  id                String                  @id @default(cuid())
  reference         String                  @unique
  type              ShipmentType
  mode              TransportMode
  status            ShipmentStatus          @default(DRAFT)
  origin            String
  destination       String
  carrier           String?
  trackingNumber    String?
  weight            Float?
  volume            Float?
  description       String?
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  userId            String
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  quoteId           String?
  quote             Quote?                  @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  documents         Document[]
  trackingEvents    TrackingEvent[]
  payment           Payment?
  customsRecord     CustomsRecord?
  foodImport        FoodImport?
  expediente        ImportExpediente?
  statusHistory     ShipmentStatusHistory[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([userId])
  @@index([status])
  @@index([trackingNumber])
  @@index([userId, status])
  @@index([createdAt])
}

model ShipmentStatusHistory {
  id         String         @id @default(cuid())
  shipmentId String
  shipment   Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  status     ShipmentStatus
  notes      String?
  createdAt  DateTime       @default(now())

  @@index([shipmentId])
}

model Document {
  id           String       @id @default(cuid())
  shipmentId   String
  shipment     Shipment     @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  type         DocumentType
  name         String
  url          String
  publicId     String       @unique
  size         Int
  createdAt    DateTime     @default(now())

  @@index([shipmentId])
  @@index([uploadedById])
}

model TrackingEvent {
  id          String   @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  status      String
  location    String?
  description String
  occurredAt  DateTime
  createdAt   DateTime @default(now())

  @@index([shipmentId])
}

model Payment {
  id                    String        @id @default(cuid())
  shipmentId            String        @unique
  shipment              Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  userId                String
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount                Float
  currency              String        @default("USD")
  freightAmount         Float
  commissionAmount      Float
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?
  stripeInvoiceUrl      String?
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model CustomsRecord {
  id           String        @id @default(cuid())
  shipmentId   String        @unique
  shipment     Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  hsCode       String?
  description  String?
  value        Float?
  currency     String        @default("USD")
  tariffRate   Float?
  agent        String?
  status       CustomsStatus @default(PENDING)
  observations String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([shipmentId])
}

model FoodImport {
  id                    String           @id @default(cuid())
  shipmentId            String           @unique
  shipment              Shipment         @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  userId                String
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  cfdiData              Json
  cfdiVersion           String           @default("4.0")
  cfdiFolio             String
  cfdiSerie             String?
  cfdiFecha             String
  exporterRFC           String
  exporterName          String
  importerRFC           String
  importerNIT           String
  importerName          String

  hsCode                String
  productDescription    String

  commercialValueUSD    Float
  incoterm              String           @default("FOB")
  freightCostUSD        Float            @default(350)
  insuranceCostUSD      Float
  cifValueUSD           Float
  cifValueGTQ           Float
  exchangeRate          Float            @default(7.75)

  daiRate               Float
  daiAmountGTQ          Float
  ivaAmountGTQ          Float
  totalTributesGTQ      Float

  requiresFitosanitario Boolean          @default(false)
  requiresZoosanitario  Boolean          @default(false)
  requiresLab           Boolean          @default(false)
  requiresQuarantine    Boolean          @default(false)
  quarantineDays        Int?
  labType               String?
  estimatedProcessDays  Int              @default(10)

  pointOfEntry          String
  expectedArrivalDate   DateTime?
  sigieRequestNumber    String?          @unique
  sigieSubmittedAt      DateTime?
  sigieApproved         Boolean          @default(false)
  sigieApprovedAt       DateTime?
  labResult             String?
  labResultDate         DateTime?
  quarantineStart       DateTime?
  quarantineEnd         DateTime?
  releasedAt            DateTime?
  observations          String?

  status                FoodImportStatus @default(DRAFT)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([userId])
  @@index([status])
  @@index([shipmentId])
}

model ImportExpediente {
  id                String            @id @default(cuid())
  shipmentId        String            @unique
  shipment          Shipment          @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // CFDI
  cfdiUUID          String?
  cfdiFolio         String?
  cfdiXmlUrl        String?
  cfdiPdfUrl        String?

  // Exportador (MX)
  expNombre         String
  expRFC            String
  expCURP           String?
  expDireccion      String?

  // Importador (GT)
  impNombre         String
  impNIT            String?
  impIdFiscal       String?
  impDireccion      String?

  // Comercial
  incoterm          String
  moneda            String            @default("USD")
  tipoCambio        Float?
  totalUSD          Float
  mercancias        Json
  pesoTotalKG       Float

  // Transporte
  transporteEmpresa String?
  transporteCAAT    String?
  pilotoNombre      String?
  pilotoLicencia    String?
  cabezalPlaca      String?
  cabezalTarjeta    String?
  furgonPlaca       String?
  furgonTarjeta     String?
  numEconomico      String?
  fleteCosto        Float?

  // Aduanas
  aduanaSalidaMX    String            @default("ADUANA SUCHIATE II")
  aduanaEntradaGT   String            @default("ADUANA TECUN UMAN II")
  fechaCruce        DateTime?
  cartaPorteNum     String?
  manifiestoNum     String?
  packingListNum    String?

  // URLs documentos generados
  cartaPorteMXUrl   String?
  cartaPorteGTUrl   String?
  packingListUrl    String?

  // Fitosanitario MX
  fitoMXNumero      String?
  fitoMXFecha       DateTime?
  fitoMXUrl         String?
  fitoMXDeclaracion String?

  // Lab
  labRequerido      Boolean           @default(false)
  labNombre         String?
  labRegistro       String?
  labPlaga          String?
  labResultado      String?
  labUrl            String?

  // SIGIE/MAGA
  sigieCredUser     String?
  sigieCredPass     String?
  sigieNumSolicitud String?           @unique
  sigieStatus       String            @default("PENDIENTE")
  sigieAprobadoAt   DateTime?
  sigiePermitUrl    String?

  // SAT Guatemala
  ducaDNumero       String?
  satOrdenNumero    String?
  satSemaforo       String?
  satTransmitidaAt  DateTime?
  satLiberadaAt     DateTime?

  // Tributos
  cifUSD            Float?
  daiTotal          Float?
  ivaTotal          Float?
  totalTributos     Float?

  status            ExpedienteStatus  @default(CFDI_PENDIENTE)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId])
  @@index([status])
  @@index([shipmentId])
}

model UserCredentials {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  system    String
  username  String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, system])
  @@index([userId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  description String
  metadata    Json?
  ip          String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
